# === Production-ready .env for Durar (Open WebUI) on AWS EC2 ===

# Set to 'prod' to disable Swagger docs and enable production behavior
ENV='prod'

# Required: A strong random secret key for JWT/session encryption
# Generate with: openssl rand -base64 12
WEBUI_SECRET_KEY=''

# === OpenAI (primary LLM backend) ===
OPENAI_API_BASE_URL='https://api.openai.com/v1'
OPENAI_API_KEY=''

# === Server Configuration ===
HOST='0.0.0.0'
PORT='8080'
UVICORN_WORKERS='2'

# Set this to your actual domain (NOT wildcard in production)
CORS_ALLOW_ORIGIN='https://your-domain.com'

# Set to the proxy IP if behind nginx/CDN, otherwise '127.0.0.1'
FORWARDED_ALLOW_IPS='127.0.0.1'

# === Database (defaults to SQLite; switch to PostgreSQL for production) ===
# DATABASE_URL='postgresql://user:password@localhost:5432/durar'

# === Redis (optional, recommended for multi-worker WebSocket support) ===
# REDIS_URL='redis://localhost:6379'

# === Authentication ===
ENABLE_SIGNUP='false'
ENABLE_LOGIN_FORM='true'
JWT_EXPIRES_IN='1440'

# === DO NOT TRACK ===
SCARF_NO_ANALYTICS='true'
DO_NOT_TRACK='true'
ANONYMIZED_TELEMETRY='false'
